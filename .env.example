# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values for the provider you want.
# Only fill in ONE provider section -- whichever LLM_PROVIDER you choose below.
# ---------------------------------------------------------------------------

# Web search (required for all providers) -- free key at https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# Which LLM backend to use: "gemini", "groq", or "ollama"
LLM_PROVIDER=groq

# Optional: override the default model for your chosen provider.
# Defaults if left blank:
#   gemini -> gemini/gemini-2.0-flash
#   groq   -> groq/llama-3.3-70b-versatile
#   ollama -> ollama/llama3.1
MODEL_NAME=

# --- Gemini (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Groq (https://console.groq.com/keys) ---
GROQ_API_KEY=

# --- Ollama (local models, no API key needed) ---
# Make sure `ollama serve` is running and you've pulled a model, e.g.:
#   ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
